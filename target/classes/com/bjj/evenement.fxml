<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bjj.controller.EvenementController"
            prefWidth="800" prefHeight="550">

    <top>
        <VBox style="-fx-padding: 15; -fx-background-color: #2196F3;">
            <Label text="🏆 Gestion des Événements"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </top>

    <center>
        <SplitPane>
            <!-- Liste des événements -->
            <VBox spacing="10" style="-fx-padding: 15;">
                <Label text="Liste des événements" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tableEvenements" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="100"/>
                        <TableColumn fx:id="colLieu" text="Lieu" prefWidth="120"/>
                        <TableColumn fx:id="colSport" text="Sport" prefWidth="120"/>
                        <TableColumn fx:id="colMax" text="Max" prefWidth="50"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="12" style="-fx-padding: 15;">
                <Label text="Ajouter / Modifier" style="-fx-font-weight: bold;"/>

                <VBox spacing="5">
                    <Label text="Nom de l'événement :"/>
                    <TextField fx:id="nomField" promptText="Ex: Tournoi BJJ Tahiti"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Date :"/>
                    <DatePicker fx:id="datePicker" promptText="JJ/MM/AAAA"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Lieu :"/>
                    <TextField fx:id="lieuField" promptText="Ex: Papeete"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Sport :"/>
                    <ComboBox fx:id="sportCombo" prefWidth="200"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Nombre de participants max :"/>
                    <TextField fx:id="maxField" promptText="Ex: 32"/>
                </VBox>

                <Label fx:id="messageLabel" text=""
                       style="-fx-font-size: 12px;"/>

                <HBox spacing="10">
                    <Button text="➕ Ajouter"
                            onAction="#ajouterEvenement"
                            prefWidth="110"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                    <Button text="✏️ Modifier"
                            onAction="#modifierEvenement"
                            prefWidth="110"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
                    <Button text="🗑️ Supprimer"
                            onAction="#supprimerEvenement"
                            prefWidth="110"
                            style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                </HBox>

                <Button text="🔄 Actualiser"
                        onAction="#chargerEvenements"
                        prefWidth="110"/>
            </VBox>
        </SplitPane>
    </center>

</BorderPane>