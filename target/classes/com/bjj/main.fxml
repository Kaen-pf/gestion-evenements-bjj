<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bjj.controller.MainController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #f0f2f5;">

    <top>
        <VBox>
            <!-- Header -->
            <HBox style="-fx-background-color: #1e3a5f; -fx-padding: 15 25; -fx-alignment: CENTER_LEFT; -fx-spacing: 10;">
                <Label text="GES - Gestion des Evenements Sportifs"
                       style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER"
                      style="-fx-background-color: rgba(255,255,255,0.15); -fx-padding: 8 15; -fx-background-radius: 20;">
                    <Label fx:id="roleBadge" text="ADMIN"
                           style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 2 6; -fx-background-radius: 4;"/>
                    <Label fx:id="userLabel" text=""
                           style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                </HBox>
            </HBox>

            <!-- Navigation -->
            <HBox style="-fx-background-color: #2a5298; -fx-padding: 0 10;" spacing="0" alignment="CENTER_LEFT">

                <!-- Bouton Accueil -->
                <Button fx:id="btnAccueil" text="Accueil" onAction="#afficherAccueil"
                        style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand; -fx-border-color: transparent transparent white transparent; -fx-border-width: 0 0 3 0;"/>

                <Separator orientation="VERTICAL" style="-fx-background-color: rgba(255,255,255,0.2); -fx-padding: 5 0;"/>

                <Button fx:id="btnAdmin" text="Administration" onAction="#afficherAdmin"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand;"/>
                <Button fx:id="btnSports" text="Sports" onAction="#afficherSports"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand;"/>
                <Button fx:id="btnCompetiteurs" text="Competiteurs" onAction="#afficherCompetiteurs"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand;"/>
                <Button fx:id="btnEvenements" text="Evenements" onAction="#afficherEvenements"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand;"/>
                <Button fx:id="btnInscriptions" text="Inscriptions" onAction="#afficherInscriptions"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand;"/>
                <Button fx:id="btnResultats" text="Resultats" onAction="#afficherResultats"
                        style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 12 18; -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Bouton Deconnexion bien place -->
                <Button text="Deconnexion" onAction="#seDeconnecter"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8 15; -fx-background-radius: 5; -fx-cursor: hand; -fx-margin: 0 5;"/>

            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane fx:id="contentPane"/>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #1e3a5f; -fx-padding: 8 20;" alignment="CENTER_LEFT">
            <Label fx:id="statusLabel" text="Pret"
                   style="-fx-text-fill: #90caf9; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>