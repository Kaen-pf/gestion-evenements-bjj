<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bjj.controller.ResultatController"
            prefWidth="900" prefHeight="600">

    <top>
        <VBox style="-fx-padding: 15; -fx-background-color: #2196F3;">
            <Label text="🏆 Résultats et Classements"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 15;">

            <!-- Sélection événement -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Événement :" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="evenementCombo" prefWidth="250"/>
                <Button text="🔄 Charger"
                        onAction="#chargerResultats"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
            </HBox>

            <SplitPane>
                <!-- Tableau des résultats -->
                <VBox spacing="10">
                    <Label text="Résultats" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tableResultats" prefHeight="350">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                            <TableColumn fx:id="colCompetiteur1" text="Compétiteur 1" prefWidth="130"/>
                            <TableColumn fx:id="colCompetiteur2" text="Compétiteur 2" prefWidth="130"/>
                            <TableColumn fx:id="colResultat" text="Résultat" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Formulaire + Classement -->
                <VBox spacing="12" style="-fx-padding: 10;">
                    <Label text="Enregistrer un résultat" style="-fx-font-weight: bold;"/>

                    <VBox spacing="5">
                        <Label text="Compétiteur 1 :"/>
                        <ComboBox fx:id="competiteur1Combo" prefWidth="200"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Compétiteur 2 :"/>
                        <ComboBox fx:id="competiteur2Combo" prefWidth="200"/>
                    </VBox>

                    <VBox spacing="5">
                        <Label text="Résultat :"/>
                        <TextField fx:id="resultatField" promptText="Ex: Victoire Compétiteur 1"/>
                    </VBox>

                    <Label fx:id="messageLabel" text="" style="-fx-font-size: 12px;"/>

                    <HBox spacing="10">
                        <Button text="➕ Enregistrer"
                                onAction="#enregistrerResultat"
                                prefWidth="130"
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                        <Button text="🗑️ Supprimer"
                                onAction="#supprimerResultat"
                                prefWidth="130"
                                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                    </HBox>

                    <Separator/>

                    <Label text="🏅 Classement" style="-fx-font-weight: bold;"/>
                    <TableView fx:id="tableClassement" prefHeight="200">
                        <columns>
                            <TableColumn fx:id="colPosition" text="Position" prefWidth="70"/>
                            <TableColumn fx:id="colNomClassement" text="Compétiteur" prefWidth="150"/>
                            <TableColumn fx:id="colVictoires" text="Victoires" prefWidth="80"/>
                        </columns>
                    </TableView>
                </VBox>
            </SplitPane>
        </VBox>
    </center>

</BorderPane>