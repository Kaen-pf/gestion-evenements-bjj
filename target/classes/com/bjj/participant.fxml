<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bjj.controller.ParticipantController"
            prefWidth="800" prefHeight="550">

    <top>
        <VBox style="-fx-padding: 15; -fx-background-color: #2196F3;">
            <Label text="🥋 Gestion des Participants"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </top>

    <center>
        <SplitPane>
            <!-- Liste des participants -->
            <VBox spacing="10" style="-fx-padding: 15;">
                <Label text="Liste des participants" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tableParticipants" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="40"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="120"/>
                        <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="120"/>
                        <TableColumn fx:id="colPoids" text="Poids (kg)" prefWidth="80"/>
                        <TableColumn fx:id="colCeinture" text="Ceinture" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- Formulaire -->
            <VBox spacing="12" style="-fx-padding: 15;">
                <Label text="Ajouter / Modifier" style="-fx-font-weight: bold;"/>

                <VBox spacing="5">
                    <Label text="Nom :"/>
                    <TextField fx:id="nomField" promptText="Ex: Dupont"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Prénom :"/>
                    <TextField fx:id="prenomField" promptText="Ex: Jean"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Poids (kg) :"/>
                    <TextField fx:id="poidsField" promptText="Ex: 75.5"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="Ceinture :"/>
                    <ComboBox fx:id="ceinturCombo" prefWidth="200"/>
                </VBox>

                <Label fx:id="messageLabel" text=""
                       style="-fx-font-size: 12px;"/>

                <HBox spacing="10">
                    <Button text="➕ Ajouter"
                            onAction="#ajouterParticipant"
                            prefWidth="110"
                            style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                    <Button text="✏️ Modifier"
                            onAction="#modifierParticipant"
                            prefWidth="110"
                            style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
                    <Button text="🗑️ Supprimer"
                            onAction="#supprimerParticipant"
                            prefWidth="110"
                            style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                </HBox>

                <Button text="🔄 Actualiser"
                        onAction="#chargerParticipants"
                        prefWidth="110"/>
            </VBox>
        </SplitPane>
    </center>

</BorderPane>