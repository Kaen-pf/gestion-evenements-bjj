<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.bjj.controller.DashboardController"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
    <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #f0f2f5;">

        <!-- Titre -->
        <VBox spacing="4">
            <Label fx:id="welcomeLabel" text="Bonjour !"
                   style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1e3a5f;"/>
            <Label text="Vue d'ensemble de votre application"
                   style="-fx-font-size: 13px; -fx-text-fill: #95a5a6;"/>
        </VBox>

        <!-- Cartes statistiques -->
        <HBox spacing="20">

            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: linear-gradient(to bottom right, #1e3a5f, #2a5298); -fx-padding: 22; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(30,58,95,0.4), 10, 0, 0, 4);">
                <Label text="COMPETITEURS"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7);"/>
                <Label fx:id="nbCompetiteurs" text="0"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Separator style="-fx-background-color: rgba(255,255,255,0.3);"/>
                <Label text="Total inscrits"
                       style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: linear-gradient(to bottom right, #1a6b3c, #27ae60); -fx-padding: 22; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(39,174,96,0.4), 10, 0, 0, 4);">
                <Label text="EVENEMENTS"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7);"/>
                <Label fx:id="nbEvenements" text="0"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Separator style="-fx-background-color: rgba(255,255,255,0.3);"/>
                <Label text="Total evenements"
                       style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: linear-gradient(to bottom right, #c0392b, #e74c3c); -fx-padding: 22; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(231,76,60,0.4), 10, 0, 0, 4);">
                <Label text="INSCRIPTIONS"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7);"/>
                <Label fx:id="nbInscriptions" text="0"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Separator style="-fx-background-color: rgba(255,255,255,0.3);"/>
                <Label text="Total inscriptions"
                       style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
            </VBox>

            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: linear-gradient(to bottom right, #6c3483, #9b59b6); -fx-padding: 22; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(155,89,182,0.4), 10, 0, 0, 4);">
                <Label text="SPORTS"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.7);"/>
                <Label fx:id="nbSports" text="0"
                       style="-fx-font-size: 42px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Separator style="-fx-background-color: rgba(255,255,255,0.3);"/>
                <Label text="Total sports"
                       style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 12px;"/>
            </VBox>

        </HBox>

        <!-- Prochains evenements + Top competiteurs -->
        <HBox spacing="20">

            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                <HBox style="-fx-background-color: #1e3a5f; -fx-padding: 15 20; -fx-background-radius: 12 12 0 0;" alignment="CENTER_LEFT">
                    <Label text="PROCHAINS EVENEMENTS"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="5 prochains"
                           style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);"/>
                </HBox>
                <VBox fx:id="listeEvenements" spacing="0"/>
                <Label fx:id="labelAucunEv" text="Aucun evenement a venir"
                       style="-fx-padding: 30; -fx-text-fill: #bdc3c7; -fx-font-size: 13px;"
                       visible="true"/>
            </VBox>

            <VBox spacing="0" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10, 0, 0, 3);">
                <HBox style="-fx-background-color: #1e3a5f; -fx-padding: 15 20; -fx-background-radius: 12 12 0 0;" alignment="CENTER_LEFT">
                    <Label text="TOP COMPETITEURS"
                           style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="Par victoires"
                           style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);"/>
                </HBox>
                <VBox fx:id="listeTopCompetiteurs" spacing="0"/>
                <Label fx:id="labelAucunTop" text="Aucun resultat enregistre"
                       style="-fx-padding: 30; -fx-text-fill: #bdc3c7; -fx-font-size: 13px;"
                       visible="true"/>
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>